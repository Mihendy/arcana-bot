APP_NAME=Arcana Bot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOGS_DIR=logs
ADMIN_TG_ID=123456789
DAILY_CARD_HOUR_MSK=6
DAILY_CARD_TIMEZONE=Europe/Moscow
BOT_PUBLIC_URL=https://t.me/arcana_r_bot
API_PUBLIC_BASE_URL=http://localhost:8000
# Docker: http://minio:9000  |  Local dev: http://127.0.0.1:9000
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_BASE_URL=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=arcana-media
S3_REGION=us-east-1
S3_USE_SSL=false

BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_PROXY=

OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=30
CARDS_ASSETS_DIR=app/assets/cards
FONTS_ASSETS_DIR=app/assets/fonts
OUTPUT_DIR=data/output

# Docker: db  |  Local dev: 127.0.0.1
DB_HOST=db
DB_PORT=5432
DB_NAME=arcana_bot
DB_USER=arcana_user
DB_PASSWORD=replace-with-strong-db-password
